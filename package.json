{
  "name": "rocketchat",
  "version": "0.4.0",
  "description": "Clawdbot channel plugin for RocketChat",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "clawdbot": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "rocketchat",
      "label": "RocketChat"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepare": "true"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "clawdbot": "^2026.1.24-3",
    "openclaw": "latest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
